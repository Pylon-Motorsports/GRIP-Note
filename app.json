{
  "expo": {
    "name": "GRIP Note",
    "slug": "grip-note",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/grip_logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/bg-autumn.png",
      "resizeMode": "cover",
      "backgroundColor": "#000000"
    },
    "android": {
      "package": "com.grip.note",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/grip_logo.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      "expo-sharing",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GRIP Note uses GPS to track distance during recce and rally stages."
        }
      ],
      ["expo-speech-recognition", {
        "microphonePermission": "GRIP Note uses the microphone to capture spoken pacenotes.",
        "speechRecognitionPermission": "GRIP Note uses speech recognition to convert spoken notes into text."
      }]
    ],
    "extra": {
      "eas": {
        "projectId": "fdd381ce-f292-436a-b0d5-b6ee70966a73"
      }
    }
  }
}
