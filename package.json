{
  "name": "grip",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\""
  },
  "dependencies": {
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "expo": "~55.0.4",
    "expo-dev-client": "~55.0.11",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-location": "~55.1.2",
    "expo-print": "~55.0.8",
    "expo-sensors": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-speech": "~55.0.8",
    "expo-speech-recognition": "^3.1.1",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-get-random-values": "^2.0.0",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-screens": "^4.24.0",
    "uuid": "^13.0.0"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "./jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|uuid)"
    ],
    "moduleNameMapper": {
      "^expo-file-system/next$": "<rootDir>/src/__mocks__/expo-file-system-next.js"
    },
    "testPathIgnorePatterns": [
      "testDbHelper\\.js$"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 83,
        "functions": 70,
        "lines": 86,
        "statements": 86
      }
    }
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "babel-preset-expo": "~55.0.8",
    "better-sqlite3": "^12.6.2",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^55.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "prettier": "^3.8.1",
    "react-test-renderer": "^19.2.0",
    "typescript": "^5.9.3"
  }
}
